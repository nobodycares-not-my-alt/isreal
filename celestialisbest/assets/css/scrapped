.card {
    width:160px;
    background:var(--pallet2);
    border-radius:6px;
    overflow:hidden;
    cursor:pointer;
    display:flex;
    align-items:flex-end;
    justify-content:center;
    position:relative;
    border:2px solid transparent;
    transition:border 0.2s, transform 0.2s;
    gap:10px;
}


@import url("https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700&display=swap");
@import url("/celestialisbest/assets/css/theme.css");

::-webkit-scrollbar {
  width: 5px;
}

::-webkit-scrollbar-track {
  -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
  border-radius: 10px;
}

::-webkit-scrollbar-thumb {
  border-radius: 10px;
  -webkit-box-shadow: inset 0 0 6px rgba(0, 0, 0, 0.3);
  background-color: var(--color);
}

body {
  background-color: var(--background);
  color: var(--color);
  font-family: "Inter", sans-serif;
  margin: 0;
}

.main {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  height: 100vh;
  display: flex;
}

.bg-match {
  background: var(--bg-match);
  align-items: center;
  text-align: center;
  justify-content: center;
  padding: 20px;
  border-radius: 10px;
  width: 560px;
  box-sizing: border-box;
}

.bg-match h1#main {
  font-size: 38px !important;
  margin: 0 0 18px 0;
  white-space: nowrap;
}

input.url {
  width: 450px;
  padding: 12px 15px;
  border-radius: 10px;
  border: none;
  outline: none;
  background: var(--pallet2);
  color: var(--color);
  font-size: 16px !important;
  border: 1px solid rgba(255, 255, 255, 0.2);
  transition: 0.2s;
  box-sizing: border-box;
}

input.url:focus {
  background: #181818;
}

.row-thing {
  gap: 10px;
  margin: 10px;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
}

.card {
  width: 80px;
  height: 80px;
  padding: 8px 6px;
  background: transparent;
  border-radius: 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  gap: 6px;
  cursor: pointer;
  flex-shrink: 0;
}

.card img {
  width: 50px !important;
  height: 50px !important;
  object-fit: contain;
  flex-shrink: 0;
}

.card p {
  font-size: 14px !important;
  margin: 0;
  text-align: center;
  white-space: nowrap;
}

#card2 p {
  width: 90px;
}

.footer {
  bottom: 10px;
  right: 10px;
  position: absolute;
  gap: 5px;
  display: flex;
  font-size: 14px;
}

.footer a {
  color: var(--color);
  transition: 0.1s;
  text-decoration: none;
}

.footer a:hover {
  text-decoration: underline;
}

.footer .ap,
.a2,
.a3 {
  cursor: pointer;
}

.params {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: none;
  z-index: 9999999;
  overflow: hidden;
}

.params::before {
  content: "";
  position: absolute;
  inset: 0;
  background: rgba(128, 128, 128);
  backdrop-filter: blur(10px);
  z-index: 1;
}

.params video {
  position: relative;
  z-index: 2;
}

.gradientthing {
  width: 100%;
  height: 100%;
  background: linear-gradient(
    360deg,
    #000000 0%,
    #0a0a0a 40%,
    #1a1a1a 70%,
    #2a2a2a 100%
  );
}

