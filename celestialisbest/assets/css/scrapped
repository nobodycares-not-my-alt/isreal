.updlog {
  position: absolute;
  top: 10px;
  left: 10px;
  color: var(--color);
  cursor: pointer;
  width: 40px;
}

.updlog img {
  width: 40px;
}

body[theme="light"] .updlog img {
  filter: invert(1);
}

body[theme="light"] .card img {
  filter: invert(1);
}

.upd-bg {
  position: fixed;
  inset: 0;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  background: rgba(0, 0, 0, 0.2);
  z-index: 999;
  display: none;
}

#update-log {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: var(--pallet2);
  border: 0.7px solid var(--border);
  color: var(--color);
  padding: 20px;
  border-radius: 10px;
  z-index: 1000;
  width: 40vw;
  height: 350px;
  overflow-y: auto;
}